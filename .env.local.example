# Copy to .env.local
# Django backend (Garden City Fine Cuts) — no trailing slash

# Server-side API proxy (booking, home data)
DJANGO_API_URL=http://127.0.0.1:8000

# Client-side links (staff login, rewards register) — required in browser
NEXT_PUBLIC_DJANGO_API_URL=http://127.0.0.1:8000

# On Django .env (gardencity), set to mirror production redirect locally:
# PUBLIC_SITE_URL=http://localhost:3000
