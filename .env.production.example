# Gunicorn on same host (not exposed publicly)
DJANGO_API_URL=http://127.0.0.1:8000

# Public HTTPS domain (nginx routes /login, /api, etc. to Django)
NEXT_PUBLIC_DJANGO_API_URL=https://gardencityfinecuts.co.ke

PORT=3000
